# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=FitnessTracker
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ─── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-minimum-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (development)
DATABASE_URL=sqlite+aiosqlite:///./fitness_tracker.db

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fitness_tracker

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Options: openai | gemini | ollama
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
